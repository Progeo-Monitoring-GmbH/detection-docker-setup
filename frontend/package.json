{
  "name": "progeo",
  "version": "0.0.1",
  "homepage": "https://dashboard.progeo.com",
  "scripts": {
    "start": "vite --mode development",
    "dev": "vite --host 192.168.0.107",
    "pre-build": "echo 'Running TypeScript build' && tsc",
    "build": "echo 'Running Vite build' && vite build --debug",
    "serve": "vite preview --port 3003 --host",
    "test": "vitest",
    "lint": "eslint src/**/*.{ts,tsx,js,jsx}",
    "lint-fix": "eslint --quiet --fix src/**/*.{ts,tsx,js,jsx}",
    "test:coverage": "vitest run --coverage --watch=false"
  },
  "type": "module",
  "sideEffects": false,
  "__UPDATING-COMMAND_INST__": "npm install -g npm-check-updates",
  "__UPDATING-COMMAND_RUN__": "ncu --interactive --format group",
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@vitest/coverage-v8": "^4.0.15",
    "dotenv": "^17.2.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-unused-imports": "^4.3.0",
    "jsdom": "^27.2.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "sass": "^1.94.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vite-plugin-entry-shaking": "^0.5.1",
    "vite-plugin-javascript-obfuscator": "^3.1.0",
    "vite-plugin-obfuscator": "^1.0.5",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fortawesome/fontawesome-free": "^7.1.0",
    "@mui/material": "^7.3.6",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "axios": "^1.13.2",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "bootswatch": "^5.3.8",
    "i18next": "^25.7.1",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "js-cookie": "^3.0.5",
    "jwt-decode": "^4.0.0",
    "luxon": "^3.7.2",
    "notistack": "^3.0.2",
    "react": "^19.2.1",
    "react-bootstrap": "^2.10.10",
    "react-bootstrap-icons": "^1.11.6",
    "react-bootstrap-typeahead": "^6.4.1",
    "react-data-table-component": "^7.7.0",
    "react-datepicker": "^8.10.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.68.0",
    "react-i18next": "^16.3.5",
    "react-image-crop": "^11.0.10",
    "react-paginate": "^8.3.0",
    "react-router": "^7.10.1",
    "react-scroll": "^1.9.3",
    "react-spinners": "^0.17.0",
    "react-use": "^17.6.0",
    "styled-components": "^6.1.19",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
